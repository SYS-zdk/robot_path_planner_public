<?xml version='1.0' encoding='utf-8'?>

<launch>
	<arg name="world_parameter" value="test2" />
	<arg name="robot1_x_pos" default="0.0" />
	<arg name="robot1_y_pos" default="0.0" />
	<arg name="robot1_z_pos" default="0.0" />
	<arg name="robot1_yaw" default="0.0" />
	<include file="$(find sim_env)/launch/config.launch">
		<arg name="world" value="$(arg world_parameter)" />
		<arg name="map" value="test2" />
		<arg name="robot_number" value="1" />
		<arg name="rviz_file" value="sim_env2.rviz" />
		<arg name="robot1_x_pos" value="$(arg robot1_x_pos)" />
		<arg name="robot1_y_pos" value="$(arg robot1_y_pos)" />
		<arg name="robot1_z_pos" value="$(arg robot1_z_pos)" />
		<arg name="robot1_yaw" value="$(arg robot1_yaw)" />
	</include>
</launch>
