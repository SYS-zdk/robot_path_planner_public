<launch>
    <arg name="agent_number" default="1" />
    <arg name="agent_id" default="1" />

    <!-- robot's namespace -->
    <arg name="robot_namespace" />
    <!-- whether use namespace or not -->
    <arg name="start_ns" default="false" />
    <!-- robot's type -->
    <arg name="robot" default="turtlebot3_waffle" />
    <!-- global path planner name -->
    <arg name="global_planner" default="sunshine" />
    <!-- local planner name -->
    <arg name="local_planner" default="hybridmpccorridor" />
    <!-- NOTE: leave empty ("") to let PathPlannerNode choose a suitable optimizer per global_planner. -->
    <arg name="optimizer" default="" />

    <!-- move base module -->
    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen"  >
        <!-- global planner plugin -->
        <param name="base_global_planner" value="path_planner/PathPlanner" />
        <param name="PathPlanner/planner_name" value="$(arg global_planner)" />
        <!-- Only force optimizer when explicitly set; otherwise, PathPlannerNode's toolchain will pick defaults. -->
        <param name="PathPlanner/optimizer_name" value="$(arg optimizer)" if="$(eval arg('optimizer') != '')" />

        <!-- graph search -->
        <rosparam file="$(find sim_env)/config/planner/common_planner_params.yaml" command="load" />
        <!-- <rosparam file="$(find sim_env)/config/planner/graph_planner_params.yaml" command="load"
            if="$(eval arg('global_planner')=='a_star'
                    or arg('global_planner')=='jps' 
                    or arg('global_planner')=='bi_jps' 
                    or arg('global_planner')=='gbfs'
                    or arg('global_planner')=='dijkstra'
                    or arg('global_planner')=='d_star'
                    or arg('global_planner')=='lpa_star'
                    or arg('global_planner')=='voronoi'
                    or arg('global_planner')=='d_star_lite'
                    or arg('global_planner')=='theta_star'
                    or arg('global_planner')=='lazy_theta_star'
                    or arg('global_planner')=='s_theta_star'
                    or arg('global_planner')=='hybrid_a_star'
                    or arg('global_planner')=='lazy'
                )" /> -->

        <!-- sample search -->
        <rosparam file="$(find sim_env)/config/planner/sample_planner_params.yaml" command="load"
            if="$(eval arg('global_planner')=='rrt'
                    or arg('global_planner')=='rrt_star'
                    or arg('global_planner')=='informed_rrt'
                    or arg('global_planner')=='quick_informed_rrt'
                    or arg('global_planner')=='rrt_connect'
                    or arg('global_planner')=='sunshine'
                )" /> 

        <!-- evolutionary search -->
        <rosparam file="$(find sim_env)/config/planner/evolutionary_planner_params.yaml" command="load"
            if="$(eval arg('global_planner')=='aco'
                    or arg('global_planner')=='pso'
                    or arg('global_planner')=='ga'
                )" />

        <!-- conjugate gradient -->
        <rosparam file="$(find sim_env)/config/trajectory_optimization/conjugate_gradient_params.yaml" command="load"
            if="$(eval arg('optimizer')=='conjugate_gradient')" />

        <!-- minimumsnap -->
       <rosparam file="$(find sim_env)/config/trajectory_optimization/minimumsnap_params.yaml" command="load"
            if="$(eval arg('optimizer')=='minimumsnap_optimizer')" />

        <!-- lbfgs -->
        <rosparam file="$(find sim_env)/config/trajectory_optimization/lbfgs_params.yaml" command="load"
            if="$(eval arg('optimizer')=='lbfgs')" />

        <!-- splinetrajectory (min-jerk quintic spline) -->
        <rosparam file="$(find sim_env)/config/trajectory_optimization/splinetrajectory_params.yaml" command="load"
            if="$(eval arg('optimizer')=='splinetrajectory_optimizer'
                    or arg('optimizer')=='splinetrajectory'
                    or arg('optimizer')=='spline_trajectory_optimizer'
                    or arg('optimizer')=='spline_trajectory')" />

        <!-- minco (min-jerk MINCO spline) -->
        <rosparam file="$(find sim_env)/config/trajectory_optimization/minco_spline_params.yaml" command="load"
            if="$(eval arg('optimizer')=='minco'
                or arg('optimizer')=='minco_spline_optimizer'
                or arg('optimizer')=='minco_spline'
                or arg('optimizer')=='minco_spline_opt')" />

        <!-- local planner plugin (public repo keeps only the 3 planners used by docs A/B/C) -->
        <param name="base_local_planner" value="hlpmpccorridor_local_planner/HybridMpcCorridorPlannerROS" if="$(eval arg('local_planner')=='hybridmpccorridor')" />
        <rosparam file="$(find sim_env)/config/controller/hlpmpccorridor_local_planner.yaml" command="load" if="$(eval arg('local_planner')=='hybridmpccorridor')" />

        <param name="base_local_planner" value="reachability_controller/ReachabilityController" if="$(eval arg('local_planner')=='reachability')" />
        <rosparam file="$(find sim_env)/config/controller/reachability_controller_params.yaml" command="load" if="$(eval arg('local_planner')=='reachability')" />

        <param name="base_local_planner" value="ilqr_controller/ILQRController" if="$(eval arg('local_planner')=='ilqr')" />
        <rosparam file="$(find sim_env)/config/controller/ilqr_controller_params.yaml" command="load" if="$(eval arg('local_planner')=='ilqr')" />
 
        <!-- loading navigation parameters -->
        <rosparam file="$(eval find('sim_env') + '/config/robots/' + arg('robot') + '/global_costmap_params_' + arg('robot') + '.yaml')"
            command="load" ns="global_costmap" />
        <rosparam file="$(eval find('sim_env') + '/config/robots/' + arg('robot') + '/local_costmap_params_' + arg('robot') + '.yaml')"
            command="load" ns="local_costmap" />

        <!-- costmap plugins: choose profile by local planner -->
        <rosparam file="$(find sim_env)/config/costmap/local_costmap_plugins.yaml" command="load"
            if="$(eval arg('local_planner')=='reachability')" />
        <rosparam file="$(find sim_env)/config/costmap/global_costmap_plugins.yaml" command="load"
            if="$(eval arg('local_planner')=='reachability')" />

        <rosparam file="$(find sim_env)/config/costmap/local_costmap_plugins_social.yaml" command="load"
            unless="$(eval arg('local_planner')=='reachability')" />
        <rosparam file="$(find sim_env)/config/costmap/global_costmap_plugins_social.yaml" command="load"
            unless="$(eval arg('local_planner')=='reachability')" />
        <rosparam file="$(find sim_env)/config/move_base_params.yaml" command="load" />

        <!-- set coordinate transformation namespace -->
        <param name="global_costmap/scan/sensor_frame" value="$(arg robot_namespace)/base_scan" if="$(arg start_ns)" />
        <param name="global_costmap/scan/topic" value="/$(arg robot_namespace)/scan" if="$(arg start_ns)" />
        <param name="global_costmap/obstacle_layer/scan/sensor_frame" value="$(arg robot_namespace)/base_footprint" if="$(arg start_ns)" />
        <param name="global_costmap/obstacle_layer/scan/topic" value="/$(arg robot_namespace)/scan" if="$(arg start_ns)" />
        <param name="global_costmap/global_frame" value="map" />
        <param name="global_costmap/robot_base_frame" value="$(arg robot_namespace)/base_footprint" if="$(arg start_ns)" />

        <param name="local_costmap/scan/sensor_frame" value="$(arg robot_namespace)/base_scan" if="$(arg start_ns)" />
        <param name="local_costmap/scan/topic" value="/$(arg robot_namespace)/scan" if="$(arg start_ns)" />
        <param name="local_costmap/global_frame" value="$(arg robot_namespace)/odom" if="$(arg start_ns)" />
        <param name="local_costmap/robot_base_frame" value="$(arg robot_namespace)/base_footprint" if="$(arg start_ns)" />

        <!-- centralize map -->
        <remap from="map" to="/map" />
    </node>
</launch>